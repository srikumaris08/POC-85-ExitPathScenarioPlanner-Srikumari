  width: 5px;
  height: 5px;
}
::-webkit-scrollbar-track {
  background: var(--rr-bg);
}
::-webkit-scrollbar-thumb {
  background: var(--rr-border);
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--rr-text-dim);
}

/* ── Utility Classes ──────────────────────────────────────────── */
.rr-card {
  background: var(--rr-surface);
  border: 1px solid var(--rr-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.rr-card-elevated {
  background: var(--rr-surface-2);
  border: 1px solid var(--rr-border);
  border-radius: var(--radius-lg);
}

.rr-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 8px;
  border-radius: 99px;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.rr-badge-cyan {
  background: rgba(56, 189, 248, 0.12);
  color: var(--rr-primary);
  border: 1px solid rgba(56, 189, 248, 0.25);
}

.rr-badge-indigo {
  background: rgba(129, 140, 248, 0.12);
  color: var(--rr-secondary);
  border: 1px solid rgba(129, 140, 248, 0.25);
}

.rr-badge-green {
  background: rgba(16, 185, 129, 0.12);
  color: var(--rr-success);
  border: 1px solid rgba(16, 185, 129, 0.25);
}

.rr-badge-amber {
  background: rgba(245, 158, 11, 0.12);
  color: var(--rr-warning);
  border: 1px solid rgba(245, 158, 11, 0.25);
}

/* ── Glow Animations ─────────────────────────────────────────── */
@keyframes pulseGlow {
  0%, 100% { opacity: 0.6; }
  50%       { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes shimmer {
  0%   { background-position: -200% center; }
  100% { background-position: 200% center; }
}

.animate-slide-up { animation: slideUp 0.4s ease forwards; }
.animate-fade-in  { animation: fadeIn 0.3s ease forwards; }

.glow-cyan   { box-shadow: var(--shadow-glow-cyan); }
.glow-indigo { box-shadow: var(--shadow-glow-indigo); }

/* ── Recharts Overrides ─────────────────────────────────────── */
.recharts-tooltip-wrapper .recharts-default-tooltip {
  background: var(--rr-surface) !important;
  border: 1px solid var(--rr-border) !important;
  border-radius: 8px !important;
  color: var(--rr-text) !important;
}

.recharts-cartesian-grid-horizontal line,
.recharts-cartesian-grid-vertical line {
  stroke: var(--rr-border) !important;
  stroke-opacity: 0.5 !important;
}

.recharts-text { fill: var(--rr-text-muted) !important; }

/* ── Tab Button ──────────────────────────────────────────────── */
.tab-btn {
  padding: 6px 16px;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all 0.2s ease;
  color: var(--rr-text-muted);
  background: transparent;
}

.tab-btn:hover {
  color: var(--rr-text);
  background: var(--rr-surface-2);
}

.tab-btn.active {
  color: var(--rr-primary);
  background: rgba(56, 189, 248, 0.08);
  border-color: rgba(56, 189, 248, 0.25);
}

/* ── Range Slider ────────────────────────────────────────────── */
input[type="range"] {
  -webkit-appearance: none;
  appearance: none;
  height: 4px;
  border-radius: 4px;
  background: var(--rr-border);
  outline: none;
  cursor: pointer;
}
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--rr-primary);
  cursor: pointer;
  box-shadow: 0 0 8px rgba(56, 189, 248, 0.5);
  transition: box-shadow 0.2s ease;
}
input[type="range"]::-webkit-slider-thumb:hover {
  box-shadow: 0 0 16px rgba(56, 189, 248, 0.8);
}

/* ── Select & Input Overrides ────────────────────────────────── */
select, input[type="text"] {
  background: var(--rr-surface-2);
  border: 1px solid var(--rr-border);
  color: var(--rr-text);
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 0.8rem;
  outline: none;
  transition: border-color 0.2s ease;
}
select:focus, input[type="text"]:focus {
  border-color: var(--rr-primary);
}

/* ── Sensitivity Grid ────────────────────────────────────────── */
.sensitivity-grid {
  display: grid;
  font-size: 0.72rem;
  font-family: 'JetBrains Mono', monospace;
}

.sensitivity-cell {
  padding: 6px 8px;
  text-align: center;
  border: 1px solid var(--rr-border);
  transition: background 0.2s ease;
}

.sensitivity-cell:hover {
  background: rgba(56, 189, 248, 0.08);
}
