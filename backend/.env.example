# ---------------------------------------------------------------------------
# Exit Path Scenario Planner — Backend Environment Variables (Example)
# ---------------------------------------------------------------------------
# Rename this file to .env and fill in your values.
# This file IS committed to source control — do NOT put secrets here.
# ---------------------------------------------------------------------------

# Host and port for the uvicorn dev server
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins (no trailing slashes)
# Development: http://localhost:3000
# Production:  https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000
