# ==========================================
# BACKEND (Python) Rules
# ==========================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# ==========================================
# FRONTEND (Next.js & Node) Rules
# ==========================================
# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# typescript
*.tsbuildinfo
next-env.d.ts

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel / Deployment
.vercel

# ==========================================
# GLOBAL / SYSTEM Rules
# ==========================================
.DS_Store
Thumbs.db
*.pem

# Environment Secrets — Lock down all local keys, allow template examples
.env*
!.env.example